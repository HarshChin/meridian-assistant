# Copy to `.env` and fill in. The DETERMINISTIC eval tier runs with NO key.
# Only the live agent + the judged eval tier need a key.

# Anthropic key (the standard ANTHROPIC_API_KEY name also works).
MERIDIAN_ANTHROPIC_API_KEY=

# --- Optional overrides (sensible defaults live in src/meridian/config.py) ---
# MERIDIAN_AGENT_MODEL=claude-sonnet-4-6
# MERIDIAN_CLASSIFIER_MODEL=claude-haiku-4-5-20251001
# MERIDIAN_JUDGE_MODEL=claude-sonnet-4-6
# MERIDIAN_BOOKING_API_BASE_URL=http://127.0.0.1:8000/v1
# Canonical demo clock (ISO 8601). Keeps relative-date reasoning reproducible.
# MERIDIAN_FROZEN_NOW=2026-01-20T09:00:00-05:00
