# Normalise text files to LF in the repo (consistent for macOS/Linux graders);
# Git still checks out native line endings on Windows.
* text=auto eol=lf

# Treat provided binaries as binary (no EOL munging / diffing).
*.pdf binary
*.png binary
*.jpg binary
*.ico binary

# Generated/committed retrieval index artifacts are binary-ish; don't diff them.
data/index/** binary
